<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="270" Width="410"
        WindowStartupLocation="CenterScreen"
        Background="#f4f4f4">

    <StackPanel Margin="20">
        <TextBlock Text="Labrune Dump Comparator" FontSize="18" FontWeight="Bold" Margin="0 0 0 10"/>
        <TextBlock Text="Version: 1.0" Margin="0 0 0 5"/>
        <TextBlock Text="Author: LondonCity" Margin="0 0 0 5"/>
        <TextBlock Text="Built with PowerShell and Windows Presentation Foundation" Margin="0 0 0 5"/>
        <TextBlock Text="© 2026" Margin="0 0 0 20"/>
        <TextBlock Margin="0 0 0 5">
            <Hyperlink x:Name="GithubLink"
                NavigateUri="https://github.com/londoncity99cx">
                https://github.com/londoncity99cx
            </Hyperlink>
        </TextBlock>
        <Button x:Name="BtnClose" Content="Close" Width="80" HorizontalAlignment="Right"/>
    </StackPanel>
</Window>
