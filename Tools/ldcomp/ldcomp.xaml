<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Labrune Dump Comparator for NFSCO" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#f4f4f4">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Datei 1 -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <Label Content="File 1 (BASIS):" Width="85"/>
            <TextBox x:Name="File1Box" Width="550" Margin="0 0 10 0"/>
            <Button x:Name="BtnFile1" Content="Select" Width="96"/>
        </StackPanel>

        <!-- Datei 2 -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0 0 0 10">
            <Label Content="File 2:" Width="85"/>
            <TextBox x:Name="File2Box" Width="550" Margin="0 0 10 0"/>
            <Button x:Name="BtnFile2" Content="Select" Width="96"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0 0 0 10">
            <Button x:Name="BtnCompare" Content="Compare" Width="150" Height="30" Margin="0 0 10 0"/>
            <Button x:Name="BtnSave" Content="Save Result" Width="150" Height="30" Margin="0 0 10 0" IsEnabled="False"/>
            <Button x:Name="BtnSplitView" Content="Split View" Width="120" Height="30" Margin="0 0 10 0"/>
            <Button x:Name="BtnAbout" Content="About" Width="100" Height="30"/>
        </StackPanel>

        <!-- Ausgabe -->
        <RichTextBox x:Name="OutputBox" Grid.Row="3" Background="White" BorderBrush="#ccc" BorderThickness="1" FontFamily="Consolas" FontSize="13"/>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="4" Margin="0 10 0 0" Foreground="#666"/>
    </Grid>
</Window>
